#!/usr/bin/env bash
set -euo pipefail
LC_ALL=C

# ========= 可配置区域（也可通过外部策略文件覆盖，见注释） =========
# 1) 敏感词（用于 commit message 与注释行）
#    - 默认：常见中英文关键词 + 常见 AKIA/私钥头
DEFAULT_SENSITIVE_PATTERN='密钥|密码|口令|token|secret|api[_-]?key|access[_-]?key|private[_-]?key|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----'

# 2) 禁止的扩展名（正则，结尾匹配）
DEFAULT_DENY_EXT_REGEX='\.((docx)|(zip)|(gz)|(7z)|(rar)|(tar)|(tgz)|(jar)|(war))$'

# 3) 注释行识别（针对“新增的行”）
#    识别常见注释前缀：#, //, /*, *, --, ;, <!--, """ , '''
COMMENT_PREFIX_REGEX='^\+\s*(#|//|/\*|\*|--|;|<!--|"""|'"'"'""|'"'"')'

# 4) 可选的策略文件（若存在则覆盖默认）
POLICY_DIR="/etc/gitlab/push-policy"
KEYWORDS_FILE="${POLICY_DIR}/sensitive_keywords.txt"   # 每行一个正则/词；自动 -f 读入
DENY_EXT_FILE="${POLICY_DIR}/deny_extensions.txt"       # 每行一个扩展名（不带点），自动拼成正则
PATH_IGNORE_FILE="${POLICY_DIR}/path_ignore_globs.txt"  # 每行一个glob，匹配则跳过扫描（如 vendor/**）

# ========= 内部函数 =========
die() { echo "GL-HOOK-ERR: $*" >&2; exit 1; }

build_deny_ext_regex() {
  if [[ -s "$DENY_EXT_FILE" ]]; then
    local joined ext
    joined="$(tr -s '\r\n' '\n' <"$DENY_EXT_FILE" | grep -Ev '^\s*(#|$)' | paste -sd'|' -)"
    [[ -n "${joined:-}" ]] && echo "\\.(${joined})$" || echo "$DEFAULT_DENY_EXT_REGEX"
  else
    echo "$DEFAULT_DENY_EXT_REGEX"
  fi
}

path_ignored() {
  local p="$1"
  [[ -s "$PATH_IGNORE_FILE" ]] || return 1
  while IFS= read -r pattern; do
    [[ -z "$pattern" || "$pattern" =~ ^\s*# ]] && continue
    # 使用bash的glob匹配
    if [[ "$p" == $pattern ]]; then return 0; fi
  done < <(tr -d '\r' < "$PATH_IGNORE_FILE")
  return 1
}

grep_sensitive() {
  # 使用文件列表或默认模式匹配（忽略大小写）
  if [[ -s "$KEYWORDS_FILE" ]]; then
    grep -Ei -f "$KEYWORDS_FILE"
  else
    grep -Ei "$DEFAULT_SENSITIVE_PATTERN"
  fi
}

sensitive_match_first() {
  # 提取首个命中的敏感词，用于错误提示
  if [[ -s "$KEYWORDS_FILE" ]]; then
    grep -Eio -m 1 -f "$KEYWORDS_FILE"
  else
    grep -Eio -m 1 "$DEFAULT_SENSITIVE_PATTERN"
  fi
}

list_new_commits() {
  local oldrev="$1" newrev="$2"
  if [[ "$oldrev" =~ ^0{40}$ ]]; then
    git rev-list --no-merges "$newrev" --not --all
  else
    git rev-list --no-merges "${oldrev}..${newrev}"
  fi
}

check_commit_message() {
  local commit="$1" msg hit
  msg="$(git log -1 --pretty=%B "$commit")" || return 0
  hit="$(printf '%s' "$msg" | sensitive_match_first || true)"
  if [[ -n "$hit" ]]; then
    die "Sensitive keyword found in commit message: keyword='$hit', location=commit message, commit=$commit"
  fi
}

deny_extensions() {
  local path="$1" regex="$2"
  if echo "$path" | grep -Eq "$regex"; then
    die "Forbidden file type detected: $path"
  fi
}

scan_added_comment_lines() {
  local commit="$1" path="$2"
  local line new_line_no="" content hit
  local in_block_comment=0

  # 逐行解析 unified=3 diff，定位新增行在“新文件”中的实际行号，并支持简单的多行和行尾注释状态
  while IFS= read -r line; do
    if [[ "$line" =~ ^@@[[:space:]]-[0-9]+(,[0-9]+)?[[:space:]]\+([0-9]+)(,[0-9]+)?[[:space:]]@@ ]]; then
      new_line_no="${BASH_REMATCH[2]}"
      in_block_comment=0 # 每个 hunk 重置状态
      continue
    fi

    # 跳过文件头
    if [[ "$line" =~ ^(---|\+\+\+) ]]; then
      continue
    fi

    # 提取内容部分（去掉第一列的前缀 '+', '-', ' '）
    content="${line:1}"
    local is_comment=0
    local target_text=""

    # 状态机：处理多行注释和单行/行尾注释
    if (( in_block_comment == 1 )); then
      is_comment=1
      target_text="$content"
      # A. 检查块注释是否闭合
      if [[ "$content" =~ \*/ ]] || [[ "$content" =~ \"\"\" ]] || [[ "$content" =~ \'\'\' ]]; then
        in_block_comment=0
      fi
    else
      # B. 检查是否开启块注释
      if [[ "$content" =~ /\* ]] || [[ "$content" =~ \"\"\" ]] || [[ "$content" =~ \'\'\' ]]; then
        in_block_comment=1
        is_comment=1
        target_text="$content"
        # 检查是否在同一行就闭合了
        if [[ "$content" =~ /\*.*\*/ ]] || [[ "$content" =~ \"\"\".*\"\"\" ]] || [[ "$content" =~ \'\'\'.*\'\'\' ]]; then
          in_block_comment=0
        fi
      # C. 匹配行首或行中（如代码后的）行尾注释：#, //, --, ; 等
      elif [[ "$content" =~ (^|[[:space:]])(#|//|--|;)(.*) ]]; then
        is_comment=1
        target_text="${BASH_REMATCH[3]}" # 仅提取注释内容去匹配敏感词
      # D. 匹配 Javadoc/多行注释中间常见的前导星号
      elif [[ "$content" =~ ^[[:space:]]*\* ]]; then
        is_comment=1
        target_text="$content"
      fi
    fi

    # 触发检查：只拦截“新增”的行（且确保以+开头，容错处理）
    if [[ "$line" =~ ^\+[^+]? ]]; then
      if (( is_comment == 1 )) && [[ -n "$target_text" ]]; then
        hit="$(printf '%s\n' "$target_text" | sensitive_match_first || true)"
        if [[ -n "$hit" ]]; then
          die "Sensitive keyword found in comment: keyword='$hit', location=${path}:${new_line_no:-?}, commit=$commit, line='${content}'"
        fi
      fi
      if [[ -n "$new_line_no" ]]; then
        new_line_no=$((new_line_no + 1))
      fi
    elif [[ "$line" =~ ^[[:space:]] ]]; then
      # 对于上下文不变的行，只用来维护状态机和行号
      if [[ -n "$new_line_no" ]]; then
        new_line_no=$((new_line_no + 1))
      fi
    fi
  done < <(git show --pretty=format: --unified=3 "$commit" -- "$path")
}

check_commit() {
  local commit="$1" deny_ext_regex="$2"
  # 1) commit message
  check_commit_message "$commit"

  # 2) 遍历该 commit 的变更文件（新增/修改/复制/重命名）
  while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    # 忽略某些路径（如果配置了）
    if path_ignored "$path"; then
      continue
    fi
    # 2.1 扩展名黑名单
    deny_extensions "$path" "$deny_ext_regex"

    # 2.2 仅扫描文本文件的“新增注释行”
    #     - 二进制diff不会出现以'+'开头的内容行；这里按新增行+注释前缀筛选
    scan_added_comment_lines "$commit" "$path"
  done < <(git diff-tree --no-commit-id --name-only -r --diff-filter=ACMR "$commit")
}

# ========= 主逻辑 =========
DENY_EXT_REGEX="$(build_deny_ext_regex)"

# 读取 stdin 的多行: oldrev newrev refname
while read -r oldrev newrev refname; do
  # 分支删除（newrev 为 000...）不处理
  if [[ "$newrev" =~ ^0{40}$ ]]; then
    continue
  fi
  # 遍历此次 push 引入的所有非合并提交
  while read -r commit; do
    check_commit "$commit" "$DENY_EXT_REGEX"
  done < <(list_new_commits "$oldrev" "$newrev")
done

exit 0